{
  "client": {
    "allowed_origins": [
      "http://localhost",
      "http://127.0.0.1",
      "http://localhost:8000",
      "http://127.0.0.1:8000"
    ]
  },
  "channel": {
    "namespaces": [
      {
        "name": "satellites",
        "allow_history_for_subscriber": true,
        "allow_presence_for_subscriber": true,
        "presence": true,
        "history_size": 1000,
        "history_ttl": "24h"
      }
    ]
  },
  "log": {
    "level": "debug"
  },
  "health": {
    "enabled": true
  }
}
