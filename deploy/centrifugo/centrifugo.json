{
  "client": {
    "allowed_origins": [
      "http://localhost",
      "http://127.0.0.1",
      "http://localhost:8000",
      "http://127.0.0.1:8000"
    ]
  },
  "grpc_api": {
    "enabled": true,
    "port": 10000,
    "max_receive_message_size": 10485760 
  },
  "engine": {
    "max_publish_payload_size": 10485760
  },
  "channel": {
    "namespaces": [
      {
        "name": "satellites",
        "allow_history_for_subscriber": true,
        "allow_presence_for_subscriber": true,
        "presence": true,
        "history_size": 10,
        "history_ttl": "300s"
      }
    ]
  },
  "log": {
    "level": "debug"
  },
  "health": {
    "enabled": true
  }
}
